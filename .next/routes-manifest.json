{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/aparts/[slug]",
      "regex": "^/aparts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/aparts/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/habitaciones/[slug]",
      "regex": "^/habitaciones/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/habitaciones/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/privadas/[slug]",
      "regex": "^/privadas/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/privadas/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/studios/[slug]",
      "regex": "^/studios/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/studios/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/aparts",
      "regex": "^/aparts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/aparts(?:/)?$"
    },
    {
      "page": "/habitaciones",
      "regex": "^/habitaciones(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/habitaciones(?:/)?$"
    },
    {
      "page": "/privadas",
      "regex": "^/privadas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privadas(?:/)?$"
    },
    {
      "page": "/studios",
      "regex": "^/studios(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/studios(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}